PROJECT_ID=your-gcp-project-id
SERVICE=basolato-app
REGION=asia-northeast1
PORT=8080
SECRET_NAME=basolato-app-secret-key

# Required: SHA256 for the selected Tailwind standalone binary.
# Get this from the official release checksums:
# https://github.com/tailwindlabs/tailwindcss/releases/tag/v3.4.17
TAILWIND_SHA256=replace-with-official-sha256

# Required for deploy.sh (Docker linux/amd64 build)
TAILWIND_SHA256_LINUX_X64=replace-with-linux-x64-sha256

# Optional: set only when creating/rotating the Secret Manager value.
SECRET_KEY=replace-with-a-random-secret

# Optional: override Basolato commit hash
# BASOLATO_REF=6ef054fa959d4a10421723c5ccbd3ea9b751c240

# Optional page metadata
SITE_NAME=Todo App Template
SITE_URL=https://example.com

# Optional: custom runtime service account for Cloud Run
# SERVICE_ACCOUNT=cloud-run-runtime@your-gcp-project-id.iam.gserviceaccount.com
